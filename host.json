<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Checkout demo - Floa</title>

  <link rel="stylesheet" href="./styles.css" />

  <!-- Floa Widget Standalone (preprod) -->
  <script type="module" src="https://prp-widget.floa.com/floa-widget.js"></script>

  <script>
    window.floa_widget_config = {
      offers: [],
      theme: "brand",
      amount: 15000,
      locale: "ES",
      production: false,
      country: "ES",
      pnf: "/url_pnf",
      cnx: "/url_cnx"
    };
  </script>

  <style>
    /* Estilos mínimos por si no usas styles.css */
    details.customer { margin-top: 12px }
    details.customer .grid { display: grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap: 12px; }
    details.customer .field label { display:block; font-size:.9rem; margin-bottom:4px; color:#334; }
    details.customer .field input { width:100%; padding:8px 10px; border:1px solid #ccd; border-radius:8px; }
    .methods { display:grid; grid-template-columns: repeat(2,minmax(240px,1fr)); gap:12px; }
    .method.selected { outline: 2px solid #2b6dff; border-radius: 10px; }
    .actions { margin-top: 12px; display:flex; gap:10px; align-items:center; }
    .status { font-weight: 600; }
    .status.working { color: #7a5cff; }
    .status.error { color: #c62828; }
    .status.ok { color: #2e7d32; }
    .card { background: #fff; border-radius: 12px; padding: 16px; box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .row { display:flex; gap: 12px; }
    .field { flex:1; }
    .header { margin-bottom: 10px }
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background: #f6f9ff; color:#0b2340; margin: 0; padding: 24px; }
    main.container { max-width: 980px; margin: 0 auto; }
    h1,h2,h3 { margin: 8px 0; }
    hr { margin: 16px 0; }
    small.hint { color:#5a6b7a }
    details.debug { margin-top: 10px }
    pre { background:#0b1020; color:#d8e2ff; padding:16px; border-radius:10px; overflow:auto; }
    button { padding: 10px 14px; border-radius: 10px; border: 1px solid #c9d4ff; background: #fff; cursor: pointer;}
    button:hover { background: #eef3ff; }
    button#continue[disabled] { opacity: .5; cursor:not-allowed; }
  </style>
</head>
<body>
  <main class="container">
    <header class="header">
      <h1 id="title">Checkout</h1>
      <p class="sub" id="subtitle">Demo con Widget Standalone + flujo API (Authentication → Deal Eligibility FilePage → Finalize).</p>
    </header>

    <section class="card">
      <div class="row">
        <div class="field">
          <label id="lblAmount" for="amount">Importe (€)</label>
          <input id="amount" type="number" min="1" step="0.01" value="250.00" />
          <small class="hint">El widget espera céntimos (ej: 15000 = 150€). Nosotros convertimos automáticamente.</small>
        </div>
        <div class="field">
          <label id="lblCountry" for="country">País</label>
          <select id="country">
            <option value="FR">France (FR)</option>
            <option value="ES" selected>España (ES)</option>
            <option value="IT">Italia (IT)</option>
            <option value="PT">Portugal (PT)</option>
            <option value="BE">Bélgica (BE)</option>
            <option value="NL">Países Bajos (NL)</option>
            <option value="DE">Alemania (DE)</option>
          </select>
        </div>
      </div>

      <hr />

      <h2 id="selectPayment">Selecciona un método de pago</h2>
      <div class="methods">
        <button class="method" id="btn3_nf">
          <span class="method-title" id="lbl3_nf">Pagar en 3 plazos con Floa (sin gastos)</span>
          <div class="widget" data-floa-3-nofees></div>
        </button>
        <button class="method" id="btn4_nf">
          <span class="method-title" id="lbl4_nf">Pagar en 4 plazos con Floa (sin gastos)</span>
          <div class="widget" data-floa-4-nofees></div>
        </button>
        <button class="method" id="btn3_f">
          <span class="method-title" id="lbl3_f">Pagar en 3 plazos con Floa (con gastos)</span>
          <div class="widget" data-floa-3-fees></div>
        </button>
        <button class="method" id="btn4_f">
          <span class="method-title" id="lbl4_f">Pagar en 4 plazos con Floa (con gastos)</span>
          <div class="widget" data-floa-4-fees></div>
        </button>

        <!-- NUEVO: Botón 10 plazos (solo FR). Oculto por defecto -->
        <button class="method" id="btn10_nf" style="display:none">
          <span class="method-title" id="lbl10_nf">Pagar en 10 plazos con Floa (sin gastos)</span>
          <div class="widget" data-floa-10-nofees></div>
        </button>
      </div>

      <!-- Datos del cliente -->
      <h2>Datos del cliente</h2>
      <details class="customer" open>
        <summary>Ver/editar datos que se enviarán a FLOA</summary>
        <div class="grid">
          <div class="field"><label>trustLevel</label><input id="c_trustLevel" value="Trusted" /></div>
          <div class="field"><label>firstName</label><input id="c_firstName" value="Test" /></div>
          <div class="field"><label>lastName</label><input id="c_lastName" value="User" /></div>
          <div class="field"><label>birthDate</label><input id="c_birthDate" type="date" value="1979-07-16" /></div>
          <div class="field"><label>mobilePhoneNumber</label><input id="c_mobile" value="+33654321098" /></div>
          <div class="field"><label>email</label><input id="c_email" type="email" value="ivan.delalamohernandez@floa.com" /></div>

          <div class="field"><label>birthCountryCode</label><input id="c_birthCountryCode" value="ES" /></div>
          <div class="field"><label>birthCity</label><input id="c_birthCity" value="Madrid" /></div>

          <div class="field"><label>homeAddress.line1</label><input id="c_addr_line1" value="1 Main street" /></div>
          <div class="field"><label>homeAddress.zipCode</label><input id="c_addr_zip" value="33000" /></div>
          <div class="field"><label>homeAddress.city</label><input id="c_addr_city" value="Bordeaux" /></div>
          <div class="field"><label>homeAddress.countryCode</label><input id="c_addr_cc" value="ES" /></div>

          <div class="field"><label>taxIdNumber</label><input id="c_taxIdNumber" placeholder="(opcional por país)" /></div>
        </div>

        <h3>Preview del payload (resumen cliente)</h3>
        <pre id="customer_preview"></pre>
      </details>

      <div class="actions">
        <button id="continue" disabled>Continuar</button>
        <div id="status" class="status"></div>
      </div>

      <details class="debug">
        <summary>Debug</summary>
        <pre id="debug"></pre>
      </details>
    </section>

    <footer class="footer">
      <p>
        Widget test URL:
        <a href="https://prp-widget.floa.com/index.html" target="_blank" rel="noreferrer">prp-widget.floa.com/index.html</a>
      </p>
    </footer>
  </main>

  <script src="./app.js"></script>
</body>
</html>